# ============================================================
# Lucky Guess Backend — Root Environment Variables
# Place this file at the backend root as `.env`.
# Same variables as `Lucky Guess/.env.example` — pick one
# location to define them (the root file takes precedence
# because app.js loads it first).
# ============================================================

# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ── Google OAuth (optional) ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
